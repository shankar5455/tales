# ──────────────────────────────────────────────────────────────
# Awetalesis — .env.example
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Google Cloud ──────────────────────────────────────────────
# Required for Speech-to-Text, Language Detection, and Translation.
# Obtain at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PROJECT_ID=your_google_project_id_here

# ── ElevenLabs (Primary TTS) ──────────────────────────────────
# Obtain at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default voice (Rachel). Change to any voice ID from your ElevenLabs library.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Language settings ─────────────────────────────────────────
SOURCE_LANGUAGE=en
TARGET_LANGUAGE=es

# ── Audio settings ────────────────────────────────────────────
SAMPLE_RATE=16000
CHANNELS=1
CHUNK_MS=30
BUFFER_SIZE_SEC=5

# ── VAD settings ──────────────────────────────────────────────
VAD_AGGRESSIVENESS=2          # 0 (permissive) – 3 (aggressive)
VAD_SILENCE_THRESHOLD_MS=400  # ms of silence to end an utterance

# ── Noise suppression ─────────────────────────────────────────
NOISE_REDUCE_PROP_DECREASE=0.75

# ── Whisper fallback ──────────────────────────────────────────
WHISPER_MODEL_SIZE=tiny

# ── API server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
